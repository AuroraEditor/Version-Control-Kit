{"abstract":[{"type":"text","text":"Look up a Git configuration value by name within a specific repository context."}],"identifier":{"url":"doc:\/\/Version-Control\/documentation\/Version_Control\/Config\/getConfigValue(directoryURL:name:onlyLocal:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/version_control\/config\/getconfigvalue(directoryurl:name:onlylocal:)"]}],"sections":[],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getConfigValue","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"directoryURL"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10Foundation3URLV","text":"URL"},{"kind":"text","text":", "},{"text":"name","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":", ","kind":"text"},{"text":"onlyLocal","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"kind":"text","text":"?"}],"externalID":"s:15Version_Control6ConfigV03getC5Value12directoryURL4name9onlyLocalSSSg10Foundation0G0V_SSSbtKF","title":"getConfigValue(directoryURL:name:onlyLocal:)","modules":[{"name":"Version-Control"}],"symbolKind":"method","roleHeading":"Instance Method","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/Version-Control\/documentation\/Version_Control","doc:\/\/Version-Control\/documentation\/Version_Control\/Config"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getConfigValue","kind":"identifier"},{"kind":"text","text":"("},{"text":"directoryURL","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10Foundation3URLV","kind":"typeIdentifier","text":"URL"},{"text":", ","kind":"text"},{"text":"name","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"onlyLocal","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":" = false) "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"directoryURL","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The URL of the directory containing the Git repository."}]}]},{"name":"name","content":[{"inlineContent":[{"type":"text","text":"The name of the Git configuration key to look up."}],"type":"paragraph"}]},{"name":"onlyLocal","content":[{"inlineContent":[{"type":"text","text":"Whether or not the value should be retrieved from local repository settings only. "},{"text":"\n","type":"text"},{"text":"Default is ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", which means both local and global settings are considered.","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"text","text":" "},{"type":"text","text":"The string value associated with the specified Git configuration key in the context of the repository, "},{"type":"text","text":"\n"},{"type":"text","text":"or "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" if the configuration key is not found."}]}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This function retrieves a Git configuration value within the context of a specific Git repository "},{"text":"\n","type":"text"},{"type":"text","text":"by reading the repository’s path and then using the "},{"type":"codeVoice","code":"getConfigValueInPath"},{"text":" function to ","type":"text"},{"text":"\n","type":"text"},{"text":"perform the configuration value lookup.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Example:"}]},{"type":"codeListing","syntax":"swift","code":["let directoryURL = URL(fileURLWithPath: \"\/path\/to\/repo\") \/\/ Replace with the path to the Git repository","let configName = \"user.email\" \/\/ Replace with the desired configuration name","","do {","    if let configValue = try getConfigValue(directoryURL: directoryURL, name: configName, onlyLocal: true) {","        print(\"Git configuration value for '\\(configName)' in the repository: \\(configValue)\")","    } else {","        print(\"Git configuration key '\\(configName)' not found in the repository.\")","    }","} catch {","    print(\"Error looking up Git configuration value: \\(error.localizedDescription)\")","}"]}]}],"type":"unorderedList"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://Version-Control/documentation/Version_Control/Config":{"role":"symbol","title":"Config","kind":"symbol","identifier":"doc:\/\/Version-Control\/documentation\/Version_Control\/Config","abstract":[],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"Config","kind":"identifier"}],"navigatorTitle":[{"text":"Config","kind":"identifier"}],"url":"\/documentation\/version_control\/config","type":"topic"},"doc://Version-Control/documentation/Version_Control/Config/getConfigValue(directoryURL:name:onlyLocal:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getConfigValue","kind":"identifier"},{"text":"(","kind":"text"},{"text":"directoryURL","kind":