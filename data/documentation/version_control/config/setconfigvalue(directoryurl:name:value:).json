itory.\")","} catch {","    print(\"Error setting Git configuration value: \\(error.localizedDescription)\")","}"],"type":"codeListing","syntax":"swift"}]}],"type":"unorderedList"}]}],"references":{"doc://Version-Control/documentation/Version_Control/Config/setConfigValue(directoryURL:name:value:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"setConfigValue"},{"kind":"text","text":"("},{"text":"directoryURL","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10Foundation3URLV","text":"URL"},{"text":", ","kind":"text"},{"text":"name","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"},{"text":", ","kind":"text"},{"text":"value","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"}],"title":"setConfigValue(directoryURL:name:value:)","identifier":"doc:\/\/Version-Control\/documentation\/Version_Control\/Config\/setConfigValue(directoryURL:name:value:)","kind":"symbol","abstract":[{"text":"Sets a Git configuration value within a specific repository context.","type":"text"}],"role":"symbol","url":"\/documentation\/version_control\/config\/setconfigvalue(directoryurl:name:value:)","type":"topic"},"doc://Version-Control/documentation/Version_Control":{"identifier":"doc:\/\/Version-Control\/documentation\/Version_Control","url":"\/documentation\/version_control","role":"collection","abstract":[],"title":"Version-Control","kind":"symbol","type":"topic"},"doc://Version-Control/documentation/Version_Control/Config":{"role":"symbol","title":"Config","kind":"symbol","identifier":"doc:\/\/Version-Control\/documentation\/Version_Control\/Config","abstract":[],"fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"Config","kind":"identifier"}],"navigato