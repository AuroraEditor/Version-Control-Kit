{"abstract":[{"text":"Install Git LFS (Large File Storage) hooks in a Git repository.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/Version-Control\/documentation\/Version_Control","doc:\/\/Version-Control\/documentation\/Version_Control\/LFS"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"installLFSHooks","kind":"identifier"},{"kind":"text","text":"("},{"text":"directoryURL","kind":"externalParam"},{"kind":"text","text":": "},{"text":"URL","kind":"typeIdentifier","preciseIdentifier":"s:10Foundation3URLV"},{"kind":"text","text":", "},{"text":"force","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"directoryURL","content":[{"inlineContent":[{"text":"The URL of the Git repository where LFS hooks should be installed.","type":"text"}],"type":"paragraph"}]},{"name":"force","content":[{"inlineContent":[{"text":"A flag indicating whether to force the installation of hooks if they already exist.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Git LFS is an extension for handling large files in a Git repository. ","type":"text"},{"type":"text","text":"\n"},{"type":"text","text":"This function installs Git LFS hooks in the repository,"},{"text":" ","type":"text"},{"type":"text","text":"which are scripts that run at various points in the Git workflow to manage large files."}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Example:","type":"text"}],"type":"paragraph"},{"code":["let repositoryURL = URL(fileURLWithPath: \"\/path\/to\/git\/repo\")","","do {","    try installLFSHooks(directoryURL: repositoryURL, force: false)","    print(\"Git LFS hooks installed successfully.\")","} catch {","    print(\"Error: \\(error)\")","}"],"type":"codeListing","syntax":"swift"}]}]},{"type":"aside","content":[{"inlineContent":[{"text":"An error if there was an issue installing LFS hooks, ","type":"text"},{"type":"text","text":"\n"},{"text":"if the provided repository URL is invalid, or if the hooks installation is forced and fails.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Throws"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"code":"force","type":"codeVoice"},{"text":" is set to ","type":"text"},{"type":"codeVoice","code":"true"},{"text":", ","type":"text"},{"type":"text","text":"\n"},{"type":"text","text":"the function will forcibly install LFS hooks even if they already exist in the repository."}]}],"name":"Note"},{"content":[{"inlineContent":[{"text":"Installing Git LFS hooks is typically required to properly manage ","type":"text"},{"type":"text","text":"\n"},{"text":"large files in a Git repository. ","type":"text"},{"type":"text","text":"\n"},{"type":"text","text":"Make sure to call this function if your repository uses Git LFS for large file storage."}],"type":"paragraph"}],"style":"important","name":"Important","type":"aside"}],"kind":"content"}],"kind":"symbol","metadata":{"title":"installLFSHooks(directoryURL:force:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"installLFSHooks","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"directoryURL"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10Foundation3URLV","text":"URL","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"force","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"}],"modules":[{"name":"Version-Control"}],"role":"symbol",