{"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"isUsingLFS","kind":"identifier"},{"kind":"text","text":"("},{"text":"directoryURL","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10Foundation3URLV","text":"URL","kind":"typeIdentifier"},{"kind":"text","text":") "},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}]}],"kind":"declarations"},{"parameters":[{"name":"directoryURL","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The URL of the Git repository."}]}]}],"kind":"parameters"},{"content":[{"anchor":"return-value","text":"Return Value","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"true"},{"text":" if the repository is configured to track paths with Git LFS; otherwise, ","type":"text"},{"type":"codeVoice","code":"false"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Git LFS is an extension for handling large files in a Git repository,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and this function helps you determine if the repository is configured to track"},{"text":" ","type":"text"},{"type":"text","text":"any paths using Git LFS within its configuration."}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"code":["let repositoryURL = URL(fileURLWithPath: \"\/path\/to\/git\/repo\")","","do {","    let isUsingLFS = try isUsingLFS(directoryURL: repositoryURL)","    if isUsingLFS {","        print(\"The Git repository is configured to use Git LFS.\")","    } else {","        print(\"The Git repository is not using Git LFS.\")","    }","} catch {","    print(\"Error: \\(error)\")","}"],"type":"codeListing","syntax":"swift"}]}],"type":"unorderedList"},{"name":"Throws","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An error if there was an issue querying the Git repository or "},{"type":"text","text":"\n"},{"type":"text","text":"if the provided repository URL is invalid."}]}],"type":"aside","style":"note"},{"name":"Important","content":[{"inlineContent":[{"text":"This function checks whether the Git repository is configured to track ","type":"text"},{"type":"text","text":"\n"},{"text":"any paths with Git LFS in its configuration. ","type":"text"},{"text":"\n","type":"text"},{"type":"text","text":"It does not specify which paths are tracked; use "},{"code":"isTrackedByLFS","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"\n"},{"text":"to check if specific files are tracked.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"important"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Version-Control\/documentation\/Version_Control\/LFS\/isUsingLFS(directoryURL:)"},"sections":[],"metadata":{"title":"isUsingLFS(directoryURL:)","modules":[{"name":"Version-Control"}],"roleHeading":"Instance Method","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"isUsingLFS"},{"kind":"text","text":"("},{"text":"directoryURL","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"URL","kind":"typeIdentifier","preciseIdentifier":"s:10Foundation3URLV"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"role":"symbol","externalID":"s:15Version_Control3LFSV07isUsingC012directoryURLSb10Foundation0G0V_tKF"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/Version-Control\/documentation\/Version_Control","doc:\/\/Version-Control\/documentation\/Version_Control\/LFS"]]},"abst