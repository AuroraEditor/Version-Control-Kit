ram","text":"name"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"kind":"text","text":", "},{"kind":"externalParam","text":"url"},{"kind":"text","text":": "},{"text":"String","preciseIdentifier":"s:SS","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:15Version_Control9GitRemoteV","kind":"typeIdentifier","text":"GitRemote","identifier":"doc:\/\/Version-Control\/documentation\/Version_Control\/GitRemote"},{"text":"?","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The URL of the local Git repository where the remote will be added."}],"type":"paragraph"}],"name":"directoryURL"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The name for the new remote repository."}]}],"name":"name"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The URL of the remote Git repository.","type":"text"}]}],"name":"url"}]},{"content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"GitRemote"},{"text":" object representing the added remote repository with its name and URL.","type":"text"}]}],"kind":"content"},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this function to add a new Git remote repository to the local repository,"},{"text":" ","type":"text"},{"type":"text","text":"providing a name for the remote and its URL. "},{"type":"text","text":"\n"},{"text":"If the remote repository with the given name already exists,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the function updates the URL of the existing remote to the new URL."}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"code":["let localRepositoryURL = URL(fileURLWithPath: \"\/path\/to\/local\/repository\")","let remoteName = \"my-remote\"","let remoteURL = \"https:\/\/github.com\/myusername\/myrepo.git\"","","do {","    let addedRemote = try addRemote(directoryURL: localRepositoryURL, name: remoteName, url: remoteURL)","    print(\"Remote '\\(addedRemote.name)' added with URL: \\(addedRemote.url)\")","} catch {","    print(\"Error adding remote: \\(error)\")","}"],"type":"codeListing","syntax":"swift"}]}]},{"style":"note","type":"aside","content":[{"inlineContent":[{"text":"An error if there is a problem accessing the Git repository or ","type":"text"},{"text":"\n","type":"text"},{"type":"text","text":"executing the Git command to add the remote repository."}],"type":"paragraph"}],"name":"Throws"},{"content":[{"inlineContent":[{"type":"text","text":"Be cautious when passing user-provided remote names and URLs to this function, "},{"text":"\n","type":"text"},{"type":"text","text":"as it may execute arbitrary Git commands. "},{"type":"text","text":"\n"},{"text":"Ensure that input is properly validated and sanitized to prevent command injection vulnerabilities.","type":"text"}],"type":"paragraph"}],"style":"warning","type":"aside","name":"Warning"}]}],"hierarchy":{"paths":[["doc:\/\/Version-Control\/documentation\/Version_Control","doc:\/\/Version-Control\/documentation\/Version_Control\/Remote"]]},"references":{"doc://Version-Control/documentation/Version_Control":{"identifier":"doc:\/\/Version-Control\/documentation\/Version_Control","url":"\/documentation\/version_control","role":"collection","abstract":[],"title":"Version-Control","kind":"symbol","type":"topic"},"doc://Version-Control/documentation/Version_Control/Remote/addRemote(directoryURL:name:url:)":{"role":"symbol","identifier":"doc:\/\/Version-Control\/documentation\/Version_Control\/Remote\/addRemote(directoryURL:name:url:)"